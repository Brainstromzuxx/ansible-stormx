---
- hosts: all
  gather_facts: true
  tasks:
    - name: Selinux setup
      selinux:
        policy: targeted
        state: present

    - name: apply the rules for the new files
      sefcontext:
        target: /etc/webfile
        type: httpd_sys_context_t
        state: present
      register: context

    - name: Apply the changes to the disk
      ansible.builtin.command: restorecon -Rv /webfile
      when: context_changed.changed

    - name: Allow nginx to connect 69 hosts
      ansible.posix.seboolean:
      name: httpd_can_sendmail
      state: true
      presistent: true
